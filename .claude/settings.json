{
  "permissions": {
    "allow": [
      "Bash(uv run pytest*)",
      "Bash(uv run python*)",
      "Bash(uv run ruff*)",
      "Bash(uv run ty*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git push*)",
      "Bash(git ls-files*)",
      "Bash(git show*)",
      "Bash(gh pr *)",
      "Bash(uv add*)",
      "Bash(uv sync*)",
      "Bash(uv lock*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(pip install*)",
      "Bash(sudo*)",
      "Bash(curl * | *)",
      "Bash(wget * | *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && uv run ruff check . && uv run ruff format --check . && uv run ty check && uv run pytest --tb=short -q"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; if [ \"${file##*.}\" = \"py\" ]; then cd \"$(git rev-parse --show-toplevel)\" && uv run ruff format \"$file\" 2>/dev/null || true && uv run ruff check --fix \"$file\" 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  }
}
